DATABASE_URL='postgresql://user:password@host/db?sslmode=require'
PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET='change-me'
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
COOKIE_SECURE=false
NODE_ENV=development

# --- SaaS / billing ---
# Where the frontend lives; used for checkout success/cancel redirects.
FRONTEND_URL=http://localhost:3000
# Comma-separated emails that always get system_admin access (bootstrap).
SYSTEM_ADMIN_EMAILS=

# Required to encrypt billing provider secrets stored via the admin panel.
# Any sufficiently long random string (e.g. `openssl rand -base64 32`).
# Without it, system admins cannot save Stripe/PayMongo keys through the UI.
BILLING_ENCRYPTION_KEY=

# The env vars below are now OPTIONAL fallbacks. The preferred way to configure
# billing is the system_admin panel (Admin > Payment settings), which stores
# the active provider and encrypted keys in the database. DB values take
# precedence over these env vars.

# Default billing provider before any DB config exists:
# 'dev' (simulated, no payment), 'stripe', 'paymongo', or 'none'.
BILLING_PROVIDER=dev

# Stripe fallback (prefer the admin panel)
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_WEBHOOK_SECRET=

# PayMongo fallback (prefer the admin panel)
PAYMONGO_SECRET_KEY=
# Pro price in centavos (e.g. 60000 = PHP 600.00)
PAYMONGO_PRO_AMOUNT=60000
PAYMONGO_WEBHOOK_SECRET=
